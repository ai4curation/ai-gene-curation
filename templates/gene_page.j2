{% if function.gross_anatomy %}
<table>
<tr>
  <th style="width: 150px;">Anatomical Location</th>
  <td>{{ render_term(function.gross_anatomy.term) }}</td>
</tr>
{% if function.gross_anatomy.support %}
<tr>
  <th>Evidence</th>
  <td>{{ render_evidence(function.gross_anatomy.support) }}</td>
</tr>
{% endif %}

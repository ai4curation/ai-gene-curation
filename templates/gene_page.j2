</details>

<details>
<summary><strong>Phenotypes (from structured data)</strong></summary>

{% if gene.phenotypes %}
<table>
<thead>
<tr>
  <th>Mutation</th>
  <th>Effects</th>
</tr>
</thead>
<tbody>
{% for phenotype in gene.phenotypes %}
<tr>
  <td>
    {% if phenotype.mutation %}
      <strong>{{ phenotype.mutation.type | replace('_', ' ') | title }}</strong>
      {% if phenotype.mutation.variant %}
        <br><em>({{ phenotype.mutation.variant }})</em>
      {% endif %}
    {% endif %}
  </td>
  <td>
    {% if phenotype.effects %}
    <ul style="margin: 0;">
      {% for effect in phenotype.effects %}
        <li>
          {{ render_term(effect.term) }}
          {% if effect.description %}<br><em>{{ effect.description }}</em>{% endif %}
          {% if effect.mechanism %}<br><small>Mechanism: {{ effect.mechanism }}</small>{% endif %}
        </li>
      {% endfor %}
    </ul>
    {% endif %}
  </td>
</tr>
{% endfor %}
</tbody>
</table>
{% else %}
<p><em>No phenotypes defined in structured data.</em></p>
{% endif %}

</details>


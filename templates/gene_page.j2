{% if function.upstream %}
<strong>Upstream Components:</strong>
<ul>
{% for item in function.upstream %}
  <li>
    {{ render_term(item.term) }}
    {% if item.description %}<br><em>{{ item.description }}</em>{% endif %}
    {% if item.support %}<br>Evidence: {{ render_evidence(item.support) }}{% endif %}
  </li>
{% endfor %}
</ul>
{% endif %}

{% if function.downstream %}
<strong>Downstream Targets:</strong>
<ul>
{% for item in function.downstream %}
  <li>
    {{ render_term(item.term) }}
    {% if item.description %}<br><em>{{ item.description }}</em>{% endif %}
    {% if item.support %}<br>Evidence: {{ render_evidence(item.support) }}{% endif %}
  </li>
{% endfor %}
</ul>
{% endif %}

{% if function.processes %}
<strong>Biological Processes:</strong>
<ul>
{% for process in function.processes %}
  <li>
    {% if process.is_any_of %}
      One of:
      {% for alt in process.is_any_of %}
        {{ render_term(alt.term) }}{% if not loop.last %}, {% endif %}
      {% endfor %}
    {% else %}
      {{ render_term(process.term) }}
    {% endif %}
    {% if process.support or (process.is_any_of and process.is_any_of[0].support) %}
      ({{ render_evidence(process.support or process.is_any_of[0].support) }})
    {% endif %}
  </li>
{% endfor %}
</ul>
{% endif %}

{% if function.roles %}
<strong>Additional Roles:</strong>
<ul>
{% for role in function.roles %}
  <li>
    {{ render_term(role.term) }}
    {% if role.category %}<span style="color: #666;"> [{{ role.category }}]</span>{% endif %}
    {% if role.notes %}<br><em>Note: {{ role.notes }}</em>{% endif %}
    {% if role.support %}<br>Evidence: {{ render_evidence(role.support) }}{% endif %}
  </li>
{% endfor %}
</ul>
{% endif %}

</div>
